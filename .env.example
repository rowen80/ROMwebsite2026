# n8n Integration - Photo Request Intake Workflow
# Set this to your n8n webhook URL (production or local)
N8N_INTAKE_WEBHOOK_URL=http://127.0.0.1:5678/webhook/romwebsite2026/request-intake

# Secret key that matches the ROM_INTAKE_SECRET in your n8n environment variables
# Generate a random string - this must match n8n's ROM_INTAKE_SECRET exactly
N8N_INTAKE_SECRET=your-secret-key-here

# Legacy Zapier webhook (deprecated - only needed for password reset if still in use)
RESET_ZAPIER_WEBHOOK_URL=

# App Security - JWT token signing key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-jwt-secret-key-here

# Frontend URL (for CORS and redirects)
FRONTEND_BASE_URL=http://127.0.0.1:8000

# Pricing configuration file
PRICING_FILE=pricing.json
